# ============================================
# HOMEFINANCE - Environment Variables (Example)
# ============================================
# Copy this file to .env and fill with real values

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=homefinance

# ============================================
# BACKEND
# ============================================
NODE_ENV=development
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=seu-jwt-secret-super-seguro-mudar-em-producao
JWT_EXPIRY=7d

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=HomeFinance
VITE_APP_VERSION=5.0.0

# ============================================
# EMAIL (Optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-de-app

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# PRODUCTION EXAMPLE
# ============================================
# NODE_ENV=production
# BACKEND_PORT=5000
# DB_HOST=seu-db-host.locaweb.com.br
# DB_USER=homefinance
# DB_PASSWORD=senha-super-segura
# JWT_SECRET=jwt-secret-muito-seguro
# VITE_API_URL=https://seu-dominio.com.br/api
# CORS_ORIGIN=https://seu-dominio.com.br
